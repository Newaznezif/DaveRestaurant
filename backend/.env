NODE_ENV=development
PORT=4000
API_PREFIX=api
API_VERSION=v1

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/daverestaurant?schema=public

REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

JWT_ACCESS_SECRET=dev-access-secret-key-min-32-chars-long!!
JWT_REFRESH_SECRET=dev-refresh-secret-key-min-32-chars-long!
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

ENCRYPTION_KEY=dev-encryption-key-32-chars-long!!

FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

THROTTLE_TTL=60000
THROTTLE_LIMIT=100

LOG_LEVEL=debug
LOG_FORMAT=json

SWAGGER_ENABLED=true
SWAGGER_TITLE=DaveRestaurant API
SWAGGER_DESCRIPTION=Enterprise Restaurant Management System API
SWAGGER_VERSION=1.0

SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@daverestaurant.com

STORAGE_DRIVER=local

# ==================== OAUTH ====================
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret
FACEBOOK_CALLBACK_URL=http://localhost:4000/api/auth/facebook/callback

UPLOAD_MAX_SIZE=5242880
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/webp,application/pdf
UPLOAD_DEST=./uploads