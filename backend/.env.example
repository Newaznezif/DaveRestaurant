# ==================== APPLICATION ====================
NODE_ENV=development
PORT=4000
API_PREFIX=api
API_VERSION=v1

# ==================== DATABASE ====================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/daverestaurant?schema=public

# ==================== REDIS ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ==================== JWT ====================
JWT_ACCESS_SECRET=your-access-secret-min-32-chars-long
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars-long
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ==================== ENCRYPTION ====================
ENCRYPTION_KEY=your-32-char-encryption-key-here!

# ==================== CORS ====================
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ==================== THROTTLE ====================
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# ==================== LOGGING ====================
LOG_LEVEL=debug
LOG_FORMAT=json

# ==================== SWAGGER ====================
SWAGGER_ENABLED=true
SWAGGER_TITLE=DaveRestaurant API
SWAGGER_DESCRIPTION=Enterprise Restaurant Management System API
SWAGGER_VERSION=1.0

# ==================== EMAIL ====================
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@daverestaurant.com

# ==================== STORAGE ====================
STORAGE_DRIVER=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_BUCKET=

# ==================== PAYMENT ====================
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# ==================== OAUTH ====================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/v1/auth/google/callback
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_CALLBACK_URL=http://localhost:4000/api/v1/auth/facebook/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:4000/api/v1/auth/github/callback

# ==================== RECAPTCHA ====================
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# ==================== NOTIFICATIONS ====================
FCM_SERVER_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ==================== FILE UPLOADS ====================
UPLOAD_MAX_SIZE=5242880
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/webp,application/pdf
UPLOAD_DEST=./uploads

# ==================== CLOUDINARY ====================
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=